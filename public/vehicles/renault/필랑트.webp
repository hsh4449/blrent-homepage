<script type="text/javascript">
if(document.location.protocol != 'https:'){
	location.replace('https://cdn.renault.co.kr/ko/common/error404.jsp');
}
//20240327 gradle
var tmpLoc = location.href;
var isLoc = false;
if(tmpLoc.indexOf("www.renaultkoream.com") > -1) {
	isLoc = true;
	tmpLoc = tmpLoc.replace("www.renaultkoream.com", "www.renault.co.kr");
}
if(tmpLoc.indexOf("cdn.renault.co.kr") > -1 && tmpLoc.indexOf("upload") == -1 && tmpLoc.indexOf("files") == -1 && tmpLoc.indexOf("resource") == -1) {
	isLoc = true;
	tmpLoc = tmpLoc.replace("cdn.renault.co.kr", "www.renault.co.kr");
}
if(tmpLoc.indexOf("/new/") > -1) {
	isLoc = true;
	tmpLoc = tmpLoc.replace("/new/", "/ko/");
}
if(tmpLoc.indexOf("xm3hev_overview") > -1) {
	isLoc = true;
	tmpLoc = tmpLoc.replace("xm3hev_overview", "arkanahybrid_overview");	
}
if(tmpLoc.indexOf("xm3_overview") > -1) {
	isLoc = true;
	tmpLoc = tmpLoc.replace("xm3_overview", "arkana_overview");	
}
if(isLoc) {
	location.replace(tmpLoc);
}

</script>




<script>
//=== Kakao / Daum Tracker 차단 스크립트 ===
(function() {
  const blockedHosts = [
    'ad.daum.net',
    'adimg.daumcdn.net',
    'tiara.daum.net',
    'track.tiara.kakao.com',
    'analytics.tiara.kakao.com'
  ];

  // XMLHttpRequest 차단
  const open = XMLHttpRequest.prototype.open;
  XMLHttpRequest.prototype.open = function(method, url) {
    if (blockedHosts.some(h => url.includes(h))) {
      console.warn('[Blocked Kakao Tracker]', url);
      return; // 요청 자체를 안 보냄
    }
    return open.apply(this, arguments);
  };

  // fetch 차단
  const fetchOrig = window.fetch;
  window.fetch = function(url, ...rest) {
    if (typeof url === 'string' && blockedHosts.some(h => url.includes(h))) {
      console.warn('[Blocked Kakao Tracker]', url);
      return new Promise(() => {}); // 요청 무시
    }
    return fetchOrig(url, ...rest);
  };

  // script 태그 차단
  const origCreateElement = document.createElement;
  document.createElement = function(tag) {
    const el = origCreateElement.call(document, tag);
    if (tag === 'script') {
      const origSetAttribute = el.setAttribute;
      el.setAttribute = function(name, value) {
        if (name === 'src' && blockedHosts.some(h => value.includes(h))) {
          console.warn('[Blocked Kakao Script]', value);
          return;
        }
        return origSetAttribute.apply(this, arguments);
      };
    }
    return el;
  };
})();
//   (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
//   (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),Rr
//   m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
//   })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');

//   ga('create', 'UA-105180684-1', 'auto');
//   ga('send', 'pageview');

</script>
