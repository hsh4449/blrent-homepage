<script>
(function(){
  // 지울 쿠키 이름들 (대소문자 변형 포함)
  var names = ['UID','uid','Uid','ssid','SSID','SsId','evtuid'];

  // 도메인 후보(현재호스트 + 상위 도메인 .example.com)
  var host = location.hostname;
  var parts = host.split('.');
  var domains = [host];
  if(parts.length > 1){
    domains.push('.' + parts.slice(-2).join('.')); // example.com
    domains.push('.' + parts.slice(-3).join('.')); // sub.example.com 경우 대비
  }
  // 경로 후보
  var paths = ['/', '/;'];

  // 만료일(과거)
  var expire = 'Thu, 01 Jan 1970 00:00:00 GMT';

  function del(name){
    // 기본 삭제
    document.cookie = name + '=; Path=/; Expires=' + expire + ';';

    // 도메인/경로 조합으로 강제 삭제
    domains.forEach(function(d){
      ['/', '/;'].forEach(function(p){
        try {
          document.cookie = name + '=; Path=' + p + '; Domain=' + d + '; Expires=' + expire + '; SameSite=None; Secure';
        } catch(e){}
        try {
          document.cookie = name + '=; Path=' + p + '; Domain=' + d + '; Expires=' + expire + ';';
        } catch(e){}
      });
    });

    // httpOnly 쿠키는 JS에서 못 지우므로 서버에서 처리해야 함
  }

  names.forEach(function(n){ del(n); });

  // 페이지 로드 후에도 서드파티가 재설정하면 지워버리도록 반복 실행 (짧게)
  var tries = 0;
  var t = setInterval(function(){
    names.forEach(function(n){ del(n); });
    tries++;
    if(tries>10) clearInterval(t);
  }, 500);

  // 선택적: 보이면 콘솔에 로그 (운영서버에선 지워도 됨)
  console.info('Cookie-sanitizer executed for', names);
})();
</script>



